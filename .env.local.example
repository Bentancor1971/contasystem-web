# Copiar a .env.local y completar. NO commitear .env.local (tiene secretos).
#
# Camino rápido, si el proyecto ya está en Vercel:
#   vercel login && vercel link && vercel env pull .env.local
# baja estos valores solo, sin tener que copiarlos a mano.

# Supabase → Project Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co

# Supabase → Project Settings → API → Project API keys → anon / public
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase → Project Settings → API → Project API keys → service_role.
# SECRETO: saltea RLS. La usan los endpoints públicos de eventos (lookup,
# inscribir, reenviar-acuse), que leen tablas con RLS cerrado a anon. Sin esta
# variable el formulario público de eventos no funciona.
SUPABASE_SERVICE_ROLE_KEY=

# Secreto del cron de cumpleaños (Vercel Cron → Authorization: Bearer <valor>).
# Solo hace falta si vas a probar /api/cron/birthdays en local.
CRON_SECRET=

# Opcional, solo para desarrollo: autocompleta el login con estas credenciales.
# NEXT_PUBLIC_DEV_AUTO_LOGIN_EMAIL=
# NEXT_PUBLIC_DEV_AUTO_LOGIN_PASSWORD=
